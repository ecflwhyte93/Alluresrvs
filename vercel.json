{\n  "version": 2,\n  "builds": [\n    {\n      "src": "index.js",\n      "use": "@vercel/node"\n    }\n  ],\n  "routes": [\n    {\n      "src": "/(.*)",\n      "dest": "index.js"\n    }\n  ],\n  "env": {\n    "NODE_ENV": "production",\n    "API_URL": "https://api.example.com"\n  },\n  "headers": [\n    {\n      "source": "/(.*)",\n      "headers": [\n        {\n          "key": "Cache-Control",\n          "value": "max-age=0, s-maxage=31536000, stale-while-revalidate="\n        }\n      ]\n    }\n  ]\n}